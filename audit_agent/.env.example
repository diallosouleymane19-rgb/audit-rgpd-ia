# ═══════════════════════════════════════════════════════════════════════════
# SMD GLOBAL CONSULTING LLC — Audit RGPD/IA
# Fichier de configuration — COPIER en .env et remplir toutes les valeurs
# NE JAMAIS committer .env dans Git (ajouté dans .gitignore)
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# ANTHROPIC (Claude)
# Obtenir sur : https://console.anthropic.com/settings/keys
# ───────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-6

# ───────────────────────────────────────────────────────────────────────────
# PDF.co
# Obtenir sur : https://app.pdf.co → Settings → API Key
# ───────────────────────────────────────────────────────────────────────────
PDFCO_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL directe (non-protégée) du template Word sur Google Drive
# Drive → Partager → "Toute personne avec le lien" → Copier le lien → remplacer /view par /export?format=docx
GOOGLE_DRIVE_TEMPLATE_URL=https://drive.google.com/uc?export=download&id=XXXXXXXXXXXXXXXXXXXXXXXXXXX

# ───────────────────────────────────────────────────────────────────────────
# GMAIL — App Password SMTP
# Google Account → Sécurité → Mots de passe des applications
# Créer un mot de passe pour "Mail" → copier les 16 caractères sans espaces
# ───────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=diallosouleymane19@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_NAME=SMD GLOBAL CONSULTING LLC

# ───────────────────────────────────────────────────────────────────────────
# NOTION
# Token : https://www.notion.so/my-integrations → New Integration → Secret
# DB ID : URL de la base Notion → https://notion.so/XXXXXXXX?v=YYYYYY → XXXXXXXX
# ───────────────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ───────────────────────────────────────────────────────────────────────────
# GOOGLE DRIVE — Archivage des PDFs
# ID du dossier Drive : dans l'URL → drive.google.com/drive/folders/XXXX
# ───────────────────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optionnel — JSON du compte de service encodé en base64 (pour upload automatique)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ───────────────────────────────────────────────────────────────────────────
# APPLICATION
# ───────────────────────────────────────────────────────────────────────────
# Clé secrète pour sécuriser l'API (changer impérativement en production)
APP_SECRET_KEY=change-me-with-a-long-random-string-in-production
DEBUG=false
PORT=8000
